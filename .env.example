# =============================================================================
# Shadow-Scanner — Fichier de configuration d'environnement
# Copier ce fichier en .env et remplir les valeurs
# JAMAIS committer le fichier .env dans Git
# =============================================================================

# --- Base de données PostgreSQL ---
POSTGRES_USER=shadow_scanner
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=shadow_scanner
DATABASE_URL=postgresql+asyncpg://shadow_scanner:change_me_strong_password@db:5432/shadow_scanner

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT (min 32 caractères) ---
JWT_SECRET=change_me_in_production_min_32_chars_please!!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Application ---
ENVIRONMENT=development
# ENVIRONMENT=production

# --- APIs Externes (Tier 2 — clé gratuite requise) ---
SHODAN_API_KEY=your_shodan_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
SECURITYTRAILS_API_KEY=your_securitytrails_api_key_here
HIBP_API_KEY=your_haveibeenpwned_api_key_here
GITHUB_API_KEY=your_github_personal_access_token_here
NVD_API_KEY=your_nvd_nist_api_key_here

# --- APIs Externes (Tier 1 — sans clé requise) ---
# CRT_SH_URL=https://crt.sh
# HACKERTARGET_URL=https://api.hackertarget.com
# DNSDUMPSTER_URL=https://dnsdumpster.com
# IPAPI_URL=http://ip-api.com/json
